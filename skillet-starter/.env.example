# Spoonacular API key for the Vercel Serverless proxy.
# Get one free at https://spoonacular.com/food-api
#
# IMPORTANT: NO `VITE_` prefix. This key is read server-side by the
# Vercel Serverless Function at /api/spoonacular and never enters the
# client bundle. The proxy is what keeps it secret.
#
# Local dev: copy this file to `.env.local` and fill in the value.
# Production: set this variable in the Vercel project dashboard.

SPOONACULAR_API_KEY=your_key_here
