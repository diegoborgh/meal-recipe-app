# Spoonacular API key — used only by the Vercel Serverless Function at /api/spoonacular.
# Server-side only. Do NOT prefix with VITE_ — that would bake it into the client bundle.
#
# Local dev: copy this file to .env.local and fill in. Run `vercel dev` (not `npm run dev`)
# so the Serverless Function picks up the env var.
# Production: set SPOONACULAR_API_KEY in the Vercel project dashboard.
SPOONACULAR_API_KEY=
